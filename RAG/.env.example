# RAG System Environment Variables
# All variables are prefixed with RAG_ to avoid conflicts with Project A.

# Server
RAG_HOST=0.0.0.0
RAG_PORT=8001
RAG_PREFIX=/rag
RAG_CORS_ORIGINS=*

# Vector Store (QDRANT is the safe standalone default; PGVECTOR is opt-in)
RAG_VECTOR_STORE=QDRANT
RAG_VECTOR_STORE_PATH=./data/qdrant_db
RAG_COLLECTION_NAME=default
RAG_VECTOR_DISTANCE=cosine
RAG_EMBEDDING_SIZE=1024

# LLM and Embedding Providers (COHERE | OPENAI)
RAG_LLM_PROVIDER=COHERE
RAG_EMBEDDING_PROVIDER=COHERE
RAG_LLM_MODEL=command-a-03-2025
RAG_EMBEDDING_MODEL=embed-multilingual-v3.0

# Cloud provider credentials
RAG_COHERE_API_KEY=
RAG_OPENAI_API_KEY=
RAG_OPENAI_API_URL=

# Chunking and retrieval
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_INPUT_MAX_CHARACTERS=4096
RAG_GENERATION_MAX_TOKENS=700
RAG_GENERATION_TEMPERATURE=0.1
